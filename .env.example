# Frontend environment (Vite). Copy to `.env.local` to override.

# Where the API client sends requests. Defaults to "/api/v1", which is proxied
# to the backend in dev (see vite.config.ts). For a separately hosted API set a
# full URL, e.g. https://api.semanticguard.rw/api/v1
VITE_API_BASE_URL=/api/v1

# Backend origin used by the Vite dev proxy.
VITE_BACKEND_ORIGIN=http://127.0.0.1:5000
