# ─── SemanticGuard AI — Backend environment template ───────────────────────────
# Copy to `.env` for local development. NEVER commit the real `.env`.
# In Azure, these are injected from Key Vault / App Service settings.

# Flask
FLASK_ENV=development                       # development | testing | production
SECRET_KEY=change-me-to-a-long-random-string
APP_NAME=SemanticGuard AI
API_PREFIX=/api/v1
FRONTEND_ORIGIN=http://localhost:5173

# Database (PostgreSQL)
DATABASE_URL=postgresql+psycopg2://semanticguard:semanticguard@localhost:5432/semanticguard
SQLALCHEMY_ECHO=false

# JWT
JWT_SECRET_KEY=change-me-to-another-long-random-string
JWT_ACCESS_TOKEN_MINUTES=30
JWT_REFRESH_TOKEN_DAYS=14

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Rate limiting
RATELIMIT_STORAGE_URI=redis://localhost:6379/3
RATELIMIT_DEFAULT=200 per minute

# Email (SMTP / Flask-Mail)
# Notifications, email verification, password resets and email MFA codes are
# delivered to each user's own registered address (e.g. their personal Gmail).
# For Gmail: enable 2-Step Verification, then create an App Password
# (https://myaccount.google.com/apppasswords) and use it as MAIL_PASSWORD.
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your.account@gmail.com
MAIL_PASSWORD=your-16-char-app-password
MAIL_DEFAULT_SENDER=SemanticGuard AI <your.account@gmail.com>
# Set true to skip real sending (used automatically by the test suite).
MAIL_SUPPRESS_SEND=false
# Lifetime of one-time email MFA codes, in minutes.
EMAIL_OTP_TTL_MINUTES=10

# SMS (Africa's Talking)
AT_USERNAME=sandbox
AT_API_KEY=
AT_SENDER_ID=SEMANTIC

# Storage — provider: local | azure | minio
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./var/uploads
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=evidence
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=evidence

# Real-time — Flask-SocketIO message queue (use Redis in prod; Azure Web PubSub optional)
SOCKETIO_MESSAGE_QUEUE=redis://localhost:6379/4
AZURE_WEBPUBSUB_CONNECTION_STRING=

# Azure Key Vault (optional — when set, secrets are loaded from KV at startup)
AZURE_KEY_VAULT_URI=

# Monitoring (Application Insights)
APPLICATIONINSIGHTS_CONNECTION_STRING=

# Security
BCRYPT_ROUNDS=12
MFA_ISSUER=SemanticGuard AI
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_MINUTES=15
MAX_UPLOAD_MB=50
